# Stock Sentinel Configuration File
# Copy this to .env and update values for your environment

# ============================================================================
# General Settings
# ============================================================================
APP_NAME=StockSentinel API
ENVIRONMENT=local                    # local | staging | production
DEBUG=true

# ============================================================================
# CORS Configuration
# ============================================================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql+psycopg2://stocksentinel:password@localhost:5432/stocksentinel

# ============================================================================
# Security & JWT
# ============================================================================
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# External APIs
# ============================================================================
FINNHUB_API_KEY=your_finnhub_api_key_here

# ============================================================================
# Email Configuration (Gmail SMTP)
# ============================================================================
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password          # NOT your regular password!
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_FROM_NAME="Stock Sentinel Alerts"

# Email Features
ENABLE_EMAIL_NOTIFICATIONS=true
EMAIL_NOTIFICATION_RETRY_COUNT=3

# ============================================================================
# ALERT SYSTEM CONFIGURATION
# ============================================================================

# How many minutes between duplicate alert sends (prevents email spam)
# Examples:
#   5   = Send email on new trigger, block for 5 minutes
#   10  = Send email on new trigger, block for 10 minutes (DEFAULT)
#   30  = Send email on new trigger, block for 30 minutes
#   60  = Send email on new trigger, block for 1 hour
# 
# Recommended values:
#   Development/Testing: 1-5 minutes
#   Production: 10-60 minutes
ALERT_COOLDOWN_MINUTES=10

# DEVELOPMENT MODE: Bypass cooldown for testing
# Set to 'true' to immediately trigger alerts multiple times (for testing)
# Set to 'false' for production (enforces 10-minute cooldown)
# WARNING: Only set to true locally! Never in production!
ALERT_DEV_MODE=false

# Log verbose cooldown messages (shows every skipped trigger)
# Set to 'false' in production to reduce log spam
ALERT_LOG_COOLDOWN_CHECKS=true

# ============================================================================
# Notes on Gmail Configuration
# ============================================================================
# 
# To enable Gmail SMTP authentication:
# 
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows (or your OS)"
# 3. Google will generate a 16-character password
# 4. Copy that password to MAIL_PASSWORD above
# 5. Your regular Gmail password WON'T WORK - must use app password
#
# Error "Login failed"? Most likely because:
# - Using regular Gmail password instead of app password
# - 2FA not enabled (required for app passwords)
# - Email address incorrect
#
# Testing email configuration:
#   python -c "from app.services.email_service import send_email_with_retry; \
#   import asyncio; \
#   asyncio.run(send_email_with_retry('test@example.com', 'Test', 'Body'))"

# ============================================================================
# Alert Testing Examples
# ============================================================================
#
# Test alerts with commands:
#
# PowerShell:
#   cd backend
#   .\test_alerts.ps1                 # Production mode
#   .\test_alerts.ps1 -DevMode         # Dev mode (no cooldown)
#
# Check logs:
#   tail -f logs/app.log | grep -E "(ALERT|cooldown|Re-arm)"
#
# Check database:
#   docker exec -it stocksentinel-db psql -U stocksentinel -d stocksentinel
#   Select * FROM alert_history ORDER BY triggered_at DESC;
#   Select * FROM alerts WHERE is_active ORDER BY created_at DESC;

